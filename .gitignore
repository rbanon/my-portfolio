/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# build / compiled output
/dist
/dist-ssr
/out-tsc
/build
/bazel-out
/tmp

# Angular
/.angular/cache

# testing
/coverage

# misc
.DS_Store
Thumbs.db
*.pem
*.local
/connect.lock
/libpeerconnection.log
testem.log
/typings
/sass-cache
